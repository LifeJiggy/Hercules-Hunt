{
  "_meta": {
    "version": "2.0",
    "description": "Context-aware severity matrix for JS vulnerability findings",
    "severity_order": ["CRITICAL", "HIGH", "MEDIUM", "LOW", "INFO"],
    "cvss_version": "3.1"
  },
  "base_severity_by_class": {
    "Cross-Site Scripting (XSS)": { "base": "HIGH", "base_cvss": 7.5, "range": [6.5, 9.1] },
    "DOM-Based XSS": { "base": "HIGH", "base_cvss": 7.0, "range": [5.5, 8.5] },
    "Prototype Pollution": { "base": "HIGH", "base_cvss": 8.0, "range": [6.5, 9.5] },
    "Mass Assignment": { "base": "HIGH", "base_cvss": 7.5, "range": [6.0, 8.5] },
    "Authentication / Token": { "base": "HIGH", "base_cvss": 7.0, "range": [5.5, 9.5] },
    "SSRF": { "base": "HIGH", "base_cvss": 8.0, "range": [6.5, 9.5] },
    "Command Injection": { "base": "CRITICAL", "base_cvss": 9.0, "range": [8.0, 10.0] },
    "Path Traversal": { "base": "HIGH", "base_cvss": 7.5, "range": [6.0, 9.0] },
    "IDOR": { "base": "HIGH", "base_cvss": 7.5, "range": [5.5, 8.5] },
    "Broken Access Control": { "base": "HIGH", "base_cvss": 7.5, "range": [6.0, 9.0] },
    "WebSocket": { "base": "MEDIUM", "base_cvss": 6.0, "range": [4.0, 7.5] },
    "Business Logic": { "base": "HIGH", "base_cvss": 7.5, "range": [5.5, 9.0] },
    "Race Condition": { "base": "HIGH", "base_cvss": 8.0, "range": [6.5, 9.5] },
    "Open Redirect": { "base": "MEDIUM", "base_cvss": 6.0, "range": [4.0, 7.5] },
    "XXE": { "base": "HIGH", "base_cvss": 7.0, "range": [5.5, 8.5] },
    "SSTI": { "base": "HIGH", "base_cvss": 8.0, "range": [6.5, 9.5] },
    "SQL Injection": { "base": "CRITICAL", "base_cvss": 9.0, "range": [8.0, 10.0] },
    "File Upload": { "base": "HIGH", "base_cvss": 7.5, "range": [5.5, 9.0] },
    "CSRF": { "base": "MEDIUM", "base_cvss": 5.5, "range": [4.0, 7.0] },
    "Information Disclosure": { "base": "MEDIUM", "base_cvss": 5.5, "range": [3.0, 8.0] },
    "CORS Misconfiguration": { "base": "MEDIUM", "base_cvss": 5.0, "range": [3.5, 7.5] },
    "Next.js Specific": { "base": "HIGH", "base_cvss": 7.0, "range": [4.0, 9.1] },
    "Cryptographic Weakness": { "base": "MEDIUM", "base_cvss": 5.5, "range": [3.0, 8.0] },
    "GraphQL Vulnerabilities": { "base": "HIGH", "base_cvss": 7.0, "range": [5.0, 9.0] }
  },
  "severity_modifiers": {
    "user_input_proximity": {
      "description": "Finding near user input sinks increases severity",
      "rules": [
        { "pattern": "(?:req\\.|params|query|body|input|user)", "nearby_range": 3, "modifier": "+1.5", "severe_threshold": "HIGH" },
        { "pattern": "dangerouslySetInnerHTML|innerHTML\\s*=", "nearby_range": 1, "modifier": "+2.0", "severe_threshold": "CRITICAL" },
        { "pattern": "(?:token|jwt|secret|password|key)", "nearby_range": 5, "modifier": "+1.0", "severe_threshold": "HIGH" }
      ]
    },
    "sink_type_multiplier": {
      "description": "Certain sinks are inherently higher risk",
      "sinks": {
        "innerHTML": { "multiplier": 1.2, "cap": 9.5 },
        "outerHTML": { "multiplier": 1.15, "cap": 9.0 },
        "document.write": { "multiplier": 1.1, "cap": 8.5 },
        "eval(": { "multiplier": 1.3, "cap": 10.0 },
        "Function(": { "multiplier": 1.2, "cap": 9.5 },
        "exec(": { "multiplier": 1.4, "cap": 10.0 },
        "execSync": { "multiplier": 1.3, "cap": 10.0 },
        "spawn(": { "multiplier": 1.2, "cap": 9.5 },
        "fs.writeFile": { "multiplier": 1.25, "cap": 9.5 },
        "fs.readFile": { "multiplier": 1.1, "cap": 8.5 },
        "sequelize.query": { "multiplier": 1.3, "cap": 10.0 },
        "fetch(": { "multiplier": 1.0, "cap": 8.5 },
        "__proto__": { "multiplier": 1.2, "cap": 9.5 },
        "postMessage": { "multiplier": 0.8, "cap": 7.0 }
      }
    },
    "location_modifiers": {
      "description": "Where the finding appears influences severity",
      "node_modules": { "modifier": "-3.0", "cap": "LOW", "reason": "Library code — not your vulnerability" },
      "polyfill": { "modifier": "-4.0", "cap": "INFO", "reason": "Polyfill — no real risk" },
      "chunk-pages": { "modifier": "+1.0", "cap": "CRITICAL", "reason": "Page chunk — user-facing code" },
      "layout": { "modifier": "+0.5", "cap": "HIGH", "reason": "Layout — shared across pages" },
      "framework": { "modifier": "-2.0", "cap": "LOW", "reason": "Framework file — likely false positive" },
      "vendor": { "modifier": "-2.0", "cap": "LOW", "reason": "Vendor bundle — not your code" }
    }
  },
  "cvss_breakdown": {
    "AV": { "description": "Attack Vector", "options": { "N": 0.85, "A": 0.62, "L": 0.55, "P": 0.2 } },
    "AC": { "description": "Attack Complexity", "options": { "L": 0.77, "H": 0.44 } },
    "PR": { "description": "Privileges Required", "options": { "N": 0.85, "L": 0.62, "H": 0.27 } },
    "UI": { "description": "User Interaction", "options": { "N": 0.85, "R": 0.62 } },
    "S": { "description": "Scope", "options": { "U": 0.0, "C": 1.0 } },
    "C": { "description": "Confidentiality", "options": { "H": 0.56, "L": 0.22, "N": 0.0 } },
    "I": { "description": "Integrity", "options": { "H": 0.56, "L": 0.22, "N": 0.0 } },
    "A": { "description": "Availability", "options": { "H": 0.56, "L": 0.22, "N": 0.0 } }
  },
  "impact_weights": {
    "xss": { "C": "H", "I": "H", "A": "L", "S": "U" },
    "rce": { "C": "H", "I": "H", "A": "H", "S": "C" },
    "sqli": { "C": "H", "I": "H", "A": "H", "S": "C" },
    "ssrf": { "C": "L", "I": "L", "A": "N", "S": "U" },
    "idor": { "C": "H", "I": "L", "A": "N", "S": "U" },
    "info_disclosure": { "C": "L", "I": "N", "A": "N", "S": "U" },
    "open_redirect": { "C": "N", "I": "L", "A": "N", "S": "U" },
    "prototype_pollution": { "C": "H", "I": "H", "A": "L", "S": "C" },
    "mass_assignment": { "C": "H", "I": "H", "A": "L", "S": "U" },
    "command_injection": { "C": "H", "I": "H", "A": "H", "S": "C" },
    "path_traversal": { "C": "H", "I": "L", "A": "L", "S": "U" },
    "business_logic": { "C": "L", "I": "H", "A": "L", "S": "U" },
    "race_condition": { "C": "L", "I": "H", "A": "L", "S": "U" },
    "cors": { "C": "H", "I": "L", "A": "N", "S": "C" },
    "csrf": { "C": "L", "I": "H", "A": "L", "S": "U" },
    "ssti": { "C": "H", "I": "H", "A": "H", "S": "C" },
    "xxe": { "C": "H", "I": "L", "A": "L", "S": "U" },
    "file_upload": { "C": "H", "I": "H", "A": "H", "S": "C" },
    "auth_bypass": { "C": "H", "I": "H", "A": "H", "S": "C" },
    "websocket": { "C": "L", "I": "L", "A": "L", "S": "U" },
    "graphql": { "C": "L", "I": "L", "A": "N", "S": "U" },
    "crypto_weakness": { "C": "H", "I": "L", "A": "N", "S": "U" }
  },
  "attack_vector_mapping": {
    "XSS": "N",
    "DOM XSS": "N",
    "Prototype Pollution": "N",
    "Mass Assignment": "N",
    "SSRF": "N",
    "Command Injection": "N",
    "Path Traversal": "N",
    "IDOR": "N",
    "Open Redirect": "N",
    "SQL Injection": "N",
    "XXE": "L",
    "SSTI": "N",
    "Business Logic": "N",
    "Race Condition": "N",
    "File Upload": "N",
    "CORS": "N",
    "CSRF": "N",
    "Information Disclosure": "N",
    "Auth Bypass": "N",
    "WebSocket": "A",
    "Next.js": "N",
    "Crypto": "N",
    "GraphQL": "N"
  }
}
